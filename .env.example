# PostgreSQL — اختر واحداً:
# 1) Prisma Dev (Windows بدون Docker): npx prisma dev --detach --name tmkeen
#    ثم انسخ DATABASE_URL من: npx prisma dev ls
# 2) Docker: docker compose up -d
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"
# Session (generate: openssl rand -base64 32)
SESSION_SECRET="change-me-in-production"

# App URL (production: https://tmkeen.example.com)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# File uploads (production VPS: /var/www/tmkeen/uploads)
UPLOAD_DIR="./uploads"

# Hostinger SMTP
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-mailbox-password"
